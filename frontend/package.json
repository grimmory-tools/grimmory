{
  "name": "grimmory",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "dev": "ng serve --open --watch --configuration development",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false",
    "coverage": "ng test --watch=false --coverage",
    "coverage:summary": "node ./scripts/coverage-summary.mjs",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "lint": "pnpm run lint:eslint && pnpm run lint:styles",
    "lint:eslint": "ng lint",
    "lint:styles": "stylelint \"src/**/*.scss\" \"src/*.scss\"",
    "lint:styles:fix": "pnpm run lint:styles --fix"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.1",
    "@angular/aria": "~22.0.1",
    "@angular/cdk": "^22.0.1",
    "@angular/common": "^22.0.1",
    "@angular/compiler": "^22.0.1",
    "@angular/core": "^22.0.1",
    "@angular/forms": "^22.0.1",
    "@angular/platform-browser": "^22.0.1",
    "@angular/platform-browser-dynamic": "^22.0.1",
    "@angular/router": "^22.0.1",
    "@angular/service-worker": "^22.0.1",
    "@embedpdf/pdfium": "2.14.4",
    "@embedpdf/snippet": "2.14.4",
    "@jsverse/transloco": "^8.3.0",
    "@primeuix/themes": "^2.0.3",
    "@stomp/rx-stomp": "^2.4.0",
    "@stomp/stompjs": "^7.3.0",
    "@tanstack/angular-query-experimental": "5.101.0",
    "@tanstack/angular-table": "^8.21.4",
    "@tanstack/angular-virtual": "^5.0.4",
    "chart.js": "^4.5.1",
    "chartjs-chart-matrix": "3.0.4",
    "chartjs-plugin-datalabels": "^2.2.0",
    "class-variance-authority": "^0.7.1",
    "date-fns": "^4.4.0",
    "dompurify": "^3.4.10",
    "markdown-it": "^14.2.0",
    "ng-lazyload-image": "^9.1.3",
    "ng2-charts": "^10.0.0",
    "ngx-infinite-scroll": "^21.0.0",
    "ngx-sse-client": "^21.0.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.9",
    "rxjs": "^7.8.2",
    "tailwind-merge": "^3.6.0",
    "tslib": "^2.8.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.6.1",
    "@angular-devkit/architect": "0.2200.1",
    "@angular-devkit/schematics": "22.0.1",
    "@angular/build": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.8",
    "angular-eslint": "^22.0.0",
    "eslint": "^10.5.0",
    "jsdom": "^29.1.1",
    "ng-mocks": "^14.15.3",
    "postcss": "^8.5.15",
    "stylelint": "^17.13.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "tailwindcss": "^4.3.1",
    "tailwindcss-primeui": "0.6.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8",
    "vitest-canvas-mock": "^1.1.4"
  }
