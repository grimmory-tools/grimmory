alt="avatar" width="40" height="40" loading="lazy" decoding="async"
src="https://s.lubimyczytac.pl/upload/avatars/2253939/1021317-80x80.jpg"
data-toggle="" title=""><div class="reviewer-readBook d-flex align-items-center" title="" data-toggle="tooltip" data-original-title="książek na półce przeczytane"><span class="reviewer__ico d-inline-block my-0 pr-1"><span class="icon icon-icon-ok-white orange fs-20"></span></span><span class="reviewer__txt d-inline-block my-0"> 214 </span></div><div class="reviewer-whiteOpinion d-flex mt-sm-1 align-items-center" title="" data-toggle="tooltip" data-original-title="napisanych opinii"><span class="reviewer__ico d-inline-block my-0 pr-1"><i class="icon icon-icon-comment2 orange fs-20" aria-hidden="true"></i></span><span class="reviewer__txt d-inline-block my-0"> 117 </span></div></div><div class="col pl-0"><div id="info" data-comment-cloud class="comment-cloud"><div class="comment-cloud__postInfo d-flex ajustify-content-between align-items-baseline"><div class="reviewer-nick"><a href="/profil/2253939/xpaavils-kamola" rel="nofollow" class="blue"> xPaavils Kamola </a></div><div class="mx-3 date comment-cloud__date"> 27.05.2026 </div><div class="rating-value ml-auto p-2"><span class="icon icon-icon-star-full red"></span><span class="big-number"> 9 </span> / 10</div></div><hr class="mt-0 mb-1"><div class="comment-cloud__second"> Na półkach:<form class="formToHref js-formToHrefHover btn-link"
action="/profil/2253939/xpaavils-kamola/biblioteczka/lista?shelfs=9481212"
