{
    auto_https off
    admin off
    servers {
        protocols h1 h2 h2c
    }
}

:{$GRIMMORY_HTTP_PORT:6060} {
    route {
        root * /srv/frontend
        encode

        @backend path /api /api/* /ws /ws/* /komga /komga/*
        reverse_proxy @backend 127.0.0.1:{$GRIMMORY_BACKEND_PORT:8080} {
            transport http {
                keepalive 30s
                keepalive_idle_conns 8
            }
            flush_interval -1
        }

        @workerFiles path /ngsw-worker.js /ngsw.json /safety-worker.js /worker-basic.min.js
        handle @workerFiles {
            header Cache-Control "public, no-cache"
            file_server {
                precompressed
            }
        }

        @rootBundles path_regexp rootBundles ^/(?:.+/)?[^/]+-[A-Za-z0-9]{8,}\.(?:js|css)$
        handle @rootBundles {
            header Cache-Control "public, max-age=31536000, immutable"
            file_server {
                precompressed
            }
        }

        @mediaBundles path /media/*
        handle @mediaBundles {
            header Cache-Control "public, max-age=31536000, immutable"
            file_server {
                precompressed
            }
        }

        @bundledAssets path /assets/* /icons/* /manifest.webmanifest /favicon*
        handle @bundledAssets {
            header Cache-Control "public, max-age=86400"
            file_server {
                precompressed
            }
        }

        handle {
            try_files {path} /index.html
            header Cache-Control "public, no-cache"
            file_server {
                precompressed
            }
        }
    }
}